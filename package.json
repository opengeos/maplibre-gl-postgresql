{
  "name": "maplibre-gl-postgresql",
  "version": "0.1.0",
  "description": "A MapLibre GL JS control for querying and visualizing geospatial PostgreSQL data through DuckDB",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/types/react.d.ts",
        "default": "./dist/react.mjs"
      },
      "require": {
        "types": "./dist/types/react.d.ts",
        "default": "./dist/react.cjs"
      }
    },
    "./style.css": "./dist/maplibre-gl-postgresql.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:examples": "vite build --config vite.examples.config.ts",
    "server:build": "npm --prefix server run build",
    "server:test": "npm --prefix server test",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "maplibre",
    "maplibre-gl",
    "map",
    "postgresql",
    "postgres",
    "duckdb",
    "spatial",
    "geospatial",
    "geoarrow",
    "deck.gl",
    "plugin",
    "control",
    "react",
    "typescript"
  ],
  "author": "Qiusheng Wu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opengeos/maplibre-gl-postgresql.git"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": ">=9.3.2",
    "@deck.gl/core": ">=9.3.2",
    "@deck.gl/geo-layers": ">=9.3.2",
    "@deck.gl/layers": ">=9.3.2",
    "@deck.gl/mapbox": ">=9.3.2",
    "@geoarrow/deck.gl-geoarrow": ">=0.4.1",
    "@math.gl/polygon": ">=4.1.0",
    "@walkthru-earth/objex-utils": ">=1.5.0",
    "apache-arrow": ">=21.1.0"
  },
  "peerDependencies": {
    "maplibre-gl": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.0",
    "maplibre-gl": "^5.14.0",
    "prettier": "^3.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.0"
  }
}
